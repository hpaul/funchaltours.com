# Secrets defined here are available for reference under registry/password, env/secret, builder/secrets,
# and accessories/*/env/secret in config/deploy.yml. All secrets should be pulled from either
# password manager, ENV, or a file. DO NOT ENTER RAW CREDENTIALS HERE! This file needs to be safe for git.

# Read secrets from .env — captures everything after the FIRST = and strips surrounding quotes
read_env() { sed -n "s/^$1=//p" .env | head -1 | sed -e 's/^"\(.*\)"$/\1/' -e "s/^'\(.*\)'\$/\1/"; }

APP_KEY=$(read_env APP_KEY)
AWS_ACCESS_KEY_ID=$(read_env AWS_ACCESS_KEY_ID)
AWS_SECRET_ACCESS_KEY=$(read_env AWS_SECRET_ACCESS_KEY)
SSH_DEPLOY_KEY=$(base64 -w 0 ~/.ssh/funchaltours_deploy)
MAIL_USERNAME=$(read_env MAIL_USERNAME)
MAIL_PASSWORD=$(read_env MAIL_PASSWORD)
